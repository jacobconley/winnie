{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!**/*.tsbuildinfo",
      "!**/*.vsix",
      "!**/*.code-workspace"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "performance": {
        "noBarrelFile": "error"
      }
    }
  },
  "plugins": [
    {
      "path": "./.biome/no-effect-try.grit",
      "includes": ["**", "!**/packages/core/utils/src/try.ts"]
    }
  ]
}
